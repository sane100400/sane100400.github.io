/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.85 0.08 0), oklch(0.85 0.08 30), oklch(0.85 0.08 60), oklch(0.85 0.08 90), oklch(0.85 0.08 120), oklch(0.85 0.08 150), oklch(0.85 0.08 180), oklch(0.85 0.08 210), oklch(0.85 0.08 240), oklch(0.85 0.08 270), oklch(0.85 0.08 300), oklch(0.85 0.08 330), oklch(0.85 0.08 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.08 0), oklch(0.70 0.08 30), oklch(0.70 0.08 60), oklch(0.70 0.08 90), oklch(0.70 0.08 120), oklch(0.70 0.08 150), oklch(0.70 0.08 180), oklch(0.70 0.08 210), oklch(0.70 0.08 240), oklch(0.70 0.08 270), oklch(0.70 0.08 300), oklch(0.70 0.08 330), oklch(0.70 0.08 360))

:root
  --radius-large 0.5rem
  --content-delay 150ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  --primary: oklch(0.75 0.12 350) oklch(0.80 0.10 350)
  --page-bg: oklch(0.97 0.008 350) oklch(0.14 0.012 320)
  --card-bg: oklch(0.99 0.004 350) oklch(0.20 0.015 320)

  --btn-content: oklch(0.58 0.10 350) oklch(0.80 0.08 350)

  --btn-regular-bg: oklch(0.96 0.018 350) oklch(0.30 0.025 320)
  --btn-regular-bg-hover: oklch(0.93 0.03 350) oklch(0.35 0.03 320)
  --btn-regular-bg-active: oklch(0.90 0.05 350) oklch(0.40 0.035 320)

  --btn-plain-bg-hover: oklch(0.96 0.018 350) oklch(0.28 0.025 320)
  --btn-plain-bg-active: oklch(0.98 0.008 350) oklch(0.25 0.018 320)

  --btn-card-bg-hover: oklch(0.97 0.006 350) oklch(0.28 0.02 320)
  --btn-card-bg-active: oklch(0.94 0.015 350) oklch(0.32 0.025 320)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: oklch(0.25 0.015 350)

  --title-active: oklch(0.65 0.10 350)

  --line-divider: black(0.06) white(0.06)

  --line-color: black(0.08) white(0.08)
  --meta-divider: black(0.15) white(0.15)

  --inline-code-bg: var(--btn-regular-bg)
  --inline-code-color: var(--btn-content)
  --selection-bg: oklch(0.92 0.04 350) oklch(0.38 0.06 350)
  --codeblock-selection: oklch(0.38 0.06 350)
  --codeblock-bg: oklch(0.15 0.012 320) oklch(0.15 0.012 320)
  --codeblock-topbar-bg: oklch(0.28 0.018 320) oklch(0.11 0.010 320)

  --license-block-bg: black(0.03) var(--codeblock-bg)

  --link-underline: oklch(0.92 0.03 350) oklch(0.38 0.05 350)
  --link-hover: oklch(0.94 0.025 350) oklch(0.38 0.05 350)
  --link-active: oklch(0.90 0.035 350) oklch(0.33 0.04 350)

  --float-panel-bg: oklch(0.99 0.004 350) oklch(0.17 0.012 320)

  --scrollbar-bg-light: black(0.25)
  --scrollbar-bg-hover-light: black(0.35)
  --scrollbar-bg-active-light: black(0.45)

  --scrollbar-bg-dark: white(0.3)
  --scrollbar-bg-hover-dark: white(0.4)
  --scrollbar-bg-active-dark: white(0.5)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --color-selection-bar: rainbow-light rainbow-dark

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: oklch(0.75 0.10 180) oklch(0.78 0.10 180)
  --admonitions-color-note: oklch(0.75 0.10 250) oklch(0.78 0.10 250)
  --admonitions-color-important: oklch(0.75 0.10 310) oklch(0.78 0.10 310)
  --admonitions-color-warning: oklch(0.75 0.10 60) oklch(0.78 0.10 60)
  --admonitions-color-caution: oklch(0.65 0.15 25) oklch(0.68 0.15 25)

  --toc-badge-bg: oklch(0.94 0.025 350) var(--btn-regular-bg)
  --toc-btn-hover: oklch(0.96 0.010 350) oklch(0.20 0.015 320)
  --toc-btn-active: oklch(0.93 0.010 350) oklch(0.23 0.015 320)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.75 0.10 350) oklch(0.33 0.05 350)

  /* NGO window decoration colors */
  --window-border: oklch(0.88 0.05 350) oklch(0.32 0.03 320)
  --window-titlebar: oklch(0.94 0.03 350) oklch(0.23 0.02 320)
  --window-dot-close: oklch(0.82 0.10 15) oklch(0.72 0.12 15)
  --window-dot-minimize: oklch(0.87 0.10 90) oklch(0.77 0.12 90)
  --window-dot-maximize: oklch(0.82 0.10 150) oklch(0.72 0.12 150)
})
